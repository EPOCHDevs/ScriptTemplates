# Job Loss in the United States - Initial Claims
claims_src = economic_indicators(series_id='ICSA')()
claims_thousands = ffill(claims_src.result) / 1000

bar_ts = index()

xy_lines(
    title='Job Loss in the United States',
    category='1. Employment',
    y_axis_label='Thousands of Persons',
    y_axis_format=AxisValueFormat.IntegerFormat,
    series=LineSeriesSchema(series=[
        LineSeriesSpec(name='Initial Unemployment Claims', color=Color.Blue)
    ])
)(bar_ts, claims_thousands)
