# A Short-Term View Of Stocks
src = market_data_source(timeframe=1D)()
close = src.c

# Approximate S&P 500 index level (SPY ~ 1/10th of index)
sp500 = close * 10

bar_ts = index()

xy_lines(
    title='A Short-Term View Of Stocks',
    category='1. Short-Term View',
    y_axis_label='S&P 500 Index',
    y_axis_format=AxisValueFormat.DecimalFormat,
    y_axis_dp=0,
    series=LineSeriesSchema(series=[
        LineSeriesSpec(name='S&P 500', color=Color.Blue)
    ])
)(bar_ts, sp500)
