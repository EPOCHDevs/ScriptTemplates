# ==========================================================================
# BMO REPRODUCTION: FX CORRELATIONS TO RISK APPETITE (MOOD PROXY)
# ==========================================================================
# Source: BMO FX Macro Report, Mar 9 2026, Page 3
# Original: 6m rolling correlation of USDCCY to MOOD Index (adjusted with 1w %)
# Proxy: VIX as risk appetite proxy (inverted relationship)
#
# VIX rises when risk appetite falls, so:
#   corr(USDCCY, VIX) > 0  →  USD strengthens when risk off (safe haven flow)
#   corr(USDCCY, VIX) < 0  →  USD weakens when risk off (risk currency)
#
# This matches BMO's MOOD correlation sign convention:
#   negative = currency moves with risk appetite (risk-on currency)
#   positive = currency moves against risk appetite (safe haven)
# ==========================================================================

# --- VIX as risk appetite proxy ---
vix_r_src = economic_indicators(series_id='VIXCLS')()
vix = ffill(vix_r_src.result)
vix_chg = returns(period=5)(vix)
# Negate VIX to create risk appetite proxy: MOOD ≈ -VIX
# corr(USDCCY, -VIX) = -corr(USDCCY, VIX) which matches BMO sign convention
mood_ret = vix_chg * -1

# --- Helper: compute 6m rolling corr of USDCCY 1w return vs MOOD 1w return ---
# 130 trading days ≈ 6 months
# 65 trading days ≈ 3 months (for the "3m ago" marker)

# ==========================================================================
# G10 CURRENCIES
# ==========================================================================

# EUR (CCYUSD → negate to get USDCCY convention)
eur_fx = fx_pairs(ticker='EURUSD')()
eur_ret = returns(period=5)(eur_fx.c) * -1
eur_corr = rolling_corr(window=130)(x=eur_ret, y=mood_ret)
eur_corr_3m = eur_corr >> 65

# GBP (CCYUSD → negate)
gbp_fx = fx_pairs(ticker='GBPUSD')()
gbp_ret = returns(period=5)(gbp_fx.c) * -1
gbp_corr = rolling_corr(window=130)(x=gbp_ret, y=mood_ret)
gbp_corr_3m = gbp_corr >> 65

# JPY (inverted: USDJPY, so use directly)
jpy_fx = fx_pairs(ticker='USDJPY')()
jpy_ret = returns(period=5)(jpy_fx.c)
jpy_corr = rolling_corr(window=130)(x=jpy_ret, y=mood_ret)
jpy_corr_3m = jpy_corr >> 65

# AUD (CCYUSD → negate)
aud_fx = fx_pairs(ticker='AUDUSD')()
aud_ret = returns(period=5)(aud_fx.c) * -1
aud_corr = rolling_corr(window=130)(x=aud_ret, y=mood_ret)
aud_corr_3m = aud_corr >> 65

# CAD (inverted: USDCAD)
cad_fx = fx_pairs(ticker='USDCAD')()
cad_ret = returns(period=5)(cad_fx.c)
cad_corr = rolling_corr(window=130)(x=cad_ret, y=mood_ret)
cad_corr_3m = cad_corr >> 65

# CHF (inverted: USDCHF)
chf_fx = fx_pairs(ticker='USDCHF')()
chf_ret = returns(period=5)(chf_fx.c)
chf_corr = rolling_corr(window=130)(x=chf_ret, y=mood_ret)
chf_corr_3m = chf_corr >> 65

# NZD (CCYUSD → negate)
nzd_fx = fx_pairs(ticker='NZDUSD')()
nzd_ret = returns(period=5)(nzd_fx.c) * -1
nzd_corr = rolling_corr(window=130)(x=nzd_ret, y=mood_ret)
nzd_corr_3m = nzd_corr >> 65

# NOK (inverted: USDNOK)
nok_fx = fx_pairs(ticker='USDNOK')()
nok_ret = returns(period=5)(nok_fx.c)
nok_corr = rolling_corr(window=130)(x=nok_ret, y=mood_ret)
nok_corr_3m = nok_corr >> 65

# SEK (inverted: USDSEK)
sek_fx = fx_pairs(ticker='USDSEK')()
sek_ret = returns(period=5)(sek_fx.c)
sek_corr = rolling_corr(window=130)(x=sek_ret, y=mood_ret)
sek_corr_3m = sek_corr >> 65

