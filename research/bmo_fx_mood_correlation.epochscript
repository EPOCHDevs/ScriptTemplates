# MXN (inverted: USDMXN)
mxn_fx = fx_pairs(ticker='USDMXN')()
mxn_ret = returns(period=5)(mxn_fx.c)
mxn_corr = rolling_corr(window=130)(x=mxn_ret, y=mood_ret)
