idr_ret = returns(period=5)(idr_fx.c)
idr_corr = rolling_corr(window=130)(x=idr_ret, y=mood_ret)
idr_corr_3m = idr_corr >> 65

# CLP (inverted: USDCLP)
clp_fx = fx_pairs(ticker='USDCLP')()
clp_ret = returns(period=5)(clp_fx.c)
clp_corr = rolling_corr(window=130)(x=clp_ret, y=mood_ret)
clp_corr_3m = clp_corr >> 65

# HUF (inverted: USDHUF)
huf_fx = fx_pairs(ticker='USDHUF')()
huf_ret = returns(period=5)(huf_fx.c)
huf_corr = rolling_corr(window=130)(x=huf_ret, y=mood_ret)
huf_corr_3m = huf_corr >> 65

# PLN (inverted: USDPLN)
pln_fx = fx_pairs(ticker='USDPLN')()
pln_ret = returns(period=5)(pln_fx.c)
pln_corr = rolling_corr(window=130)(x=pln_ret, y=mood_ret)
pln_corr_3m = pln_corr >> 65

# CNH (inverted: USDCNH)
cnh_fx = fx_pairs(ticker='USDCNH')()
cnh_ret = returns(period=5)(cnh_fx.c)
cnh_corr = rolling_corr(window=130)(x=cnh_ret, y=mood_ret)
cnh_corr_3m = cnh_corr >> 65

# ==========================================================================
# GOLD (XAUUSD)
# ==========================================================================
gold_fx = fx_pairs(ticker='XAUUSD')()
gold_ret = returns(period=5)(gold_fx.c) * -1
gold_corr = rolling_corr(window=130)(x=gold_ret, y=mood_ret)
gold_corr_3m = gold_corr >> 65

# ==========================================================================
# BAR CHART: Current correlation (bars) + 3m ago (diamond overlay)
# Sorted approximately by BMO chart order (most negative to most positive)
# ==========================================================================
xy_bars(
    mode=BarMode.series,
    title='FX Correlations to Risk Appetite (VIX Proxy)',
    category='FX-VIX Correlation',
    agg=AggregationType.Last,
    data_labels=True,
    y_axis_label='6m Rolling Correlation',
    y_axis_format=AxisValueFormat.DecimalFormat,
    y_axis_dp=2,
    reference_lines=ReferenceLineSchema(lines=[
        ReferenceLine(value=0, title='Zero', color=Color.White, dash_style=DashStyle.Dash)
    ]),
    series=BarSeriesSchema(series=[
        BarSeriesSpec(name='TWD', color=Color.Blue),
        BarSeriesSpec(name='ZAR', color=Color.Blue),
        BarSeriesSpec(name='BRL', color=Color.Blue),
        BarSeriesSpec(name='AUD', color=Color.Blue),
        BarSeriesSpec(name='MXN', color=Color.Blue),
        BarSeriesSpec(name='HUF', color=Color.Blue),
        BarSeriesSpec(name='PLN', color=Color.Blue),
        BarSeriesSpec(name='EUR', color=Color.Blue),
        BarSeriesSpec(name='IDR', color=Color.Blue),
        BarSeriesSpec(name='CLP', color=Color.Blue),
        BarSeriesSpec(name='SEK', color=Color.Blue),
        BarSeriesSpec(name='NZD', color=Color.Blue),
        BarSeriesSpec(name='GBP', color=Color.Blue),
        BarSeriesSpec(name='CAD', color=Color.Blue),
        BarSeriesSpec(name='NOK', color=Color.Blue),
        BarSeriesSpec(name='KRW', color=Color.Blue),
        BarSeriesSpec(name='CHF', color=Color.Blue),
        BarSeriesSpec(name='JPY', color=Color.Blue),
        BarSeriesSpec(name='CNH', color=Color.Blue),
        BarSeriesSpec(name='Gold', color=Color.Blue),
        BarSeriesSpec(name='INR', color=Color.Blue)
    ]),
    overlay_series=LineSeriesSchema(series=[
        LineSeriesSpec(name='3m ago', color=Color.Orange, agg=AggregationType.Last, marker=MarkerSymbol.DiamondMarker),
        LineSeriesSpec(name='', color=Color.Orange, agg=AggregationType.Last, marker=MarkerSymbol.DiamondMarker),
        LineSeriesSpec(name='', color=Color.Orange, agg=AggregationType.Last, marker=MarkerSymbol.DiamondMarker),
        LineSeriesSpec(name='', color=Color.Orange, agg=AggregationType.Last, marker=MarkerSymbol.DiamondMarker),
        LineSeriesSpec(name='', color=Color.Orange, agg=AggregationType.Last, marker=MarkerSymbol.DiamondMarker),
        LineSeriesSpec(name='', color=Color.Orange, agg=AggregationType.Last, marker=MarkerSymbol.DiamondMarker),
        LineSeriesSpec(name='', color=Color.Orange, agg=AggregationType.Last, marker=MarkerSymbol.DiamondMarker),
        LineSeriesSpec(name='', color=Color.Orange, agg=AggregationType.Last, marker=MarkerSymbol.DiamondMarker),
        LineSeriesSpec(name='', color=Color.Orange, agg=AggregationType.Last, marker=MarkerSymbol.DiamondMarker),
        LineSeriesSpec(name='', color=Color.Orange, agg=AggregationType.Last, marker=MarkerSymbol.DiamondMarker),
        LineSeriesSpec(name='', color=Color.Orange, agg=AggregationType.Last, marker=MarkerSymbol.DiamondMarker),
        LineSeriesSpec(name='', color=Color.Orange, agg=AggregationType.Last, marker=MarkerSymbol.DiamondMarker),
        LineSeriesSpec(name='', color=Color.Orange, agg=AggregationType.Last, marker=MarkerSymbol.DiamondMarker),
        LineSeriesSpec(name='', color=Color.Orange, agg=AggregationType.Last, marker=MarkerSymbol.DiamondMarker),
