        LineSeriesSpec(name='', color=Color.Orange, agg=AggregationType.Last, marker=MarkerSymbol.DiamondMarker)
    ]),
    order=0
)(twd_corr, zar_corr, brl_corr, aud_corr, mxn_corr, huf_corr, pln_corr, eur_corr, idr_corr, clp_corr, sek_corr, nzd_corr, gbp_corr, cad_corr, nok_corr, krw_corr, chf_corr, jpy_corr, cnh_corr, gold_corr, inr_corr, overlays=(twd_corr_3m, zar_corr_3m, brl_corr_3m, aud_corr_3m, mxn_corr_3m, huf_corr_3m, pln_corr_3m, eur_corr_3m, idr_corr_3m, clp_corr_3m, sek_corr_3m, nzd_corr_3m, gbp_corr_3m, cad_corr_3m, nok_corr_3m, krw_corr_3m, chf_corr_3m, jpy_corr_3m, cnh_corr_3m, gold_corr_3m, inr_corr_3m))
